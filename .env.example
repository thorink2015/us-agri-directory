# Google Analytics 4
# Get your Measurement ID from: Google Analytics → Admin → Data Streams → Web → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Formspree — operator submission form
# Create a form at formspree.io, copy the form ID (e.g. xpwavqrl)
NEXT_PUBLIC_FORMSPREE_ID=

# Formspree — newsletter (optional, separate form)
# If not set, falls back to NEXT_PUBLIC_FORMSPREE_ID above
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_ID=

# Site URL — used for canonical URLs, sitemap, and OG images
NEXT_PUBLIC_SITE_URL=https://droneagricol.ro
